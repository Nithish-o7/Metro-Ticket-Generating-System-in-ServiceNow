        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {
    var startSeq = parseInt(current.starting_point.sequence_number);
    var endSeq = parseInt(current.ending_point.sequence_number);
    

    gs.info('MetroDebug: StartSeq = ' + startSeq + ', EndSeq = ' + endSeq);

    var stopsTraveled = Math.abs(endSeq - startSeq);
    gs.info('MetroDebug: StopsTraveled = ' + stopsTraveled);

    var fareGr = new GlideRecord('x_1832142_metro_0_fare_matrix_table');
    fareGr.addQuery('min_stops', '<=', stopsTraveled);
    fareGr.addQuery('max_stops', '>=', stopsTraveled);
    fareGr.query();

    if (fareGr.next()) {
        var baseFare = parseFloat(fareGr.getValue('base_fare'));
        var ticketCount = parseInt(current.no_of_ticket) || 1;
        current.total_fare = baseFare * ticketCount;
        gs.info('MetroDebug: Fare calculated = ' + current.total_fare);
    } else {
        // This will tell us if no matching bracket was found in the matrix
        gs.info('MetroDebug: No fare bracket found for ' + stopsTraveled + ' stops.');
    }
})(current, previous);]]></script>
